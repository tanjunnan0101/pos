# Copy to .env and fill in as needed. No API keys or secrets here — examples only.
# Used by scripts (e.g. Puppeteer tests) that need optional credentials.

# Login for automated tests (e.g. test-tables-page.mjs). Use tenant=1 via TENANT_ID.
# LOGIN_EMAIL=your-email@your-restaurant.com
# LOGIN_PASSWORD=your-password
# Or:
# DEMO_LOGIN_EMAIL=your-email@your-restaurant.com
# DEMO_LOGIN_PASSWORD=your-password
# TENANT_ID=1

# Provider portal test account (for testing /provider dashboard)
# PROVIDER_TEST_EMAIL=pos-provider@sakario.sg
# PROVIDER_TEST_PASSWORD=123456
